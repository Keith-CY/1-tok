{
  "name": "1-tok",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api-gateway": "CGO_ENABLED=0 go run ./cmd/api-gateway",
    "dev:bootstrap": "CGO_ENABLED=0 go run ./cmd/bootstrap",
    "build:web": "bun --cwd apps/web build",
    "dev:web": "bun --cwd apps/web dev",
    "release:compose-smoke": "./scripts/release-compose-smoke.sh",
    "release:compose-e2e": "./scripts/release-compose-e2e.sh",
    "release:compose-fnn-smoke": "./scripts/release-compose-fnn-smoke.sh",
    "release:compose-fnn-dual-node-smoke": "./scripts/release-compose-fnn-dual-node-smoke.sh",
    "release:external-deps-smoke": "./scripts/release-external-deps-smoke.sh",
    "release:abuse-smoke": "CGO_ENABLED=0 go run ./cmd/release-abuse-smoke",
    "release:fnn-dual-node-smoke": "CGO_ENABLED=0 go run ./cmd/release-fnn-dual-node-smoke",
    "release:full-persisted-local-smoke": "./scripts/release-full-persisted-local-smoke.sh",
    "lint:web": "bun --cwd apps/web lint",
    "release:full-local-smoke": "./scripts/release-full-local-smoke.sh",
    "release:services-local-smoke": "./scripts/release-services-local-smoke.sh",
    "release:portal-local-smoke": "./scripts/release-portal-local-smoke.sh",
    "release:portal-smoke": "CGO_ENABLED=0 go run ./cmd/release-portal-smoke",
    "release:smoke": "CGO_ENABLED=0 go run ./cmd/release-smoke",
    "test:coverage": "./scripts/ci/run-unit-coverage.sh",
    "test:web": "bun --cwd apps/web test",
    "test:go": "CGO_ENABLED=0 go test ./...",
    "test:contracts": "bun --cwd packages/contracts test",
    "test:integration": "./scripts/ci/run-integration-suite.sh",
    "lint:go": "golangci-lint run ./..."
  }
}
