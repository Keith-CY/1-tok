{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/alpha-portal-ux-audit.config.schema.json",
  "title": "Alpha Portal UX Audit Config",
  "description": "Rules used by alpha-portal-ux-audit.mjs",
  "type": "object",
  "required": ["canonicalLabels", "canonicalHrefPatterns"],
  "properties": {
    "canonicalLabels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalHrefPatterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
